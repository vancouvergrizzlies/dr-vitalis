# X (Twitter) API Bearer Token - required for refresh_voice to pull from X
# Create an app at https://console.x.com and copy the Bearer Token here.
# Pricing: ~$0.005 per post read. Add credits at console.x.com.
X_BEARER_TOKEN=

# Optional: override where the council database and dashboard live.
# Defaults to ~/.health-jarvis/council.db and ~/.health-jarvis/dashboard.html
# COUNCIL_DB_PATH=
# COUNCIL_DASHBOARD_PATH=
